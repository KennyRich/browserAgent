AGENT_PROVIDER=ollama
AGENT_MODEL_NAME=qwen3.5:35b-a3b-coding-nvfp4
AGENT_OLLAMA_BASE_URL=http://localhost:11434/v1
AGENT_USE_VISION=false            # set true for vision-capable models (Claude, GPT-4o, Gemini)
AGENT_HEADLESS=false
AGENT_MAX_STEPS=15
AGENT_MAX_TEXT_LENGTH=4000
AGENT_VIEWPORT_WIDTH=1280
AGENT_VIEWPORT_HEIGHT=720
AGENT_USE_HOSTED_MODEL=false
AGENT_HOSTED_OLLAMA_BASE_URL=https://your-hosted-ollama-domain.com/v1
AGENT_HOSTED_OLLAMA_API_KEY=your-api-key
AGENT_LOG_EXPERIMENTS=false

